#. Name of the plugin
msgid "YS Loco AI Translate via Gemini"
msgstr "YS Loco AI Translate via Gemini"

#. Description of the plugin
msgid "An add-on for Loco Translate to provide automatic translations using Google Gemini API."
msgstr "Loco Translate 的擴充模組，使用 Google Gemini API 提供自動翻譯功能。"

#: includes/class-ys-gemini-settings.php:33
msgid "YS Loco AI Translate via Gemini Settings"
msgstr "YS Loco AI Gemini 翻譯設定"

#: includes/class-ys-gemini-settings.php:39
msgid "Gemini API Key"
msgstr "Gemini API 金鑰"

#: includes/class-ys-gemini-settings.php:45
msgid "Gemini Model"
msgstr "Gemini 模型"

#: includes/class-ys-gemini-settings.php:51
#. translators: %s: URL to Gemini models
msgid "Default: gemini-1.5-flash. See available models at %s"
msgstr "預設值：gemini-1.5-flash。查看可用模型請至 %s"

#: includes/class-ys-gemini-settings.php:58
msgid "Custom Prompt Template"
msgstr "自訂提示詞模板 (Prompt)"

#: includes/class-ys-gemini-settings.php:64
msgid "Use %language% for target language and %source% for source text/JSON items."
msgstr "使用 %language% 代表目標語言，%source% 代表原始文字/JSON項目。"

#: includes/class-ys-gemini-api.php:19
msgid "Gemini API Key is missing."
msgstr "缺少 Gemini API 金鑰。"

#: includes/class-ys-gemini-api.php:70
msgid "Failed to parse Gemini response as JSON."
msgstr "無法將 Gemini 回應解析為 JSON。"

#: includes/class-ys-gemini-api.php:74
msgid "Invalid response from Gemini API."
msgstr "Gemini API 回應無效。"

